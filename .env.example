# ──────────────────────────────────────────────────────────────
# SyncBoard AI+ — environment variables
# Copy this file to .env (root) for the server, and apps/web/.env.local for the web app.
# ──────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────
PORT=4000

# JWT signing secret (CHANGE THIS in production)
JWT_SECRET=dev-super-secret-change-me

# CORS / web origin
WEB_ORIGIN=http://localhost:3000

# Database
# Default: local SQLite (zero infra). The prisma schema uses sqlite by default.
# The path is resolved relative to prisma/schema.prisma → apps/server/prisma/dev.db
DATABASE_URL="file:./dev.db"
# For PostgreSQL (production), switch the provider in prisma/schema.prisma to "postgresql"
# and use a URL like:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/syncboard?schema=public"

# Redis (optional). If unset, the server uses an in-memory pub/sub + presence store
# (fine for single-instance dev). Set this to enable multi-instance scaling.
# REDIS_URL="redis://localhost:6379"

# ── AI ──────────────────────────────────────────────────
# AI provider: "heuristic" (default, no key needed) or "openai".
AI_PROVIDER=heuristic
# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Web (put these in apps/web/.env.local) ──────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
